{
  "version": 2,
  "builds": [
    {
      "src": "teide_iv/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.12"
      }
    }
  ],
  "routes": [
    {
      "src": "/estático/(.*)",
      "dest": "/staticfiles/$1"
    },
    {
      "src": "/(.*)",
      "dest": "teide_iv/wsgi.py"
    }
  ]
}
